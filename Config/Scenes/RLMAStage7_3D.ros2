<Simulation>

  <Include href="Includes/NaoV6H25.rsi2"/>
  <Include href="Includes/Ball2016SPL.rsi2"/>
  <Include href="Includes/Field2020SPL.rsi2"/>

  <Scene name="RoboCup" controller="SimulatedNao" stepLength="0.012" color="rgb(65%, 65%, 70%)" ERP="0.8" CFM="0.001" contactSoftERP="0.2" contactSoftCFM="0.005">
    <PointLight z="9m" ambientColor="rgb(50%, 50%, 50%)"/>

    <Compound name="teams">
      <Compound name="Herons">
        <Compound name="24"/>
        <Compound name="black"/>
        <Compound name="black"/>
      </Compound>
      <Compound name="Opponents">
        <Compound name="70"/>
        <Compound name="red"/>
        <Compound name="blue"/>
      </Compound>
    </Compound>

    <Compound name="location">
      <Compound name="field_e"/>
    </Compound>

    <Compound name="scenarios">
      <Compound name="4v4_RL3D"/>
    </Compound>

    <Compound name="robots">
      <Body ref="Nao" name="robot1">
        <Set name="NaoColor" value="black"/>
        <Translation x="4.10" y="0.00" z="320mm"/>
        <Rotation z="180degree"/>
      </Body>
      <Body ref="Nao" name="robot2">
        <Set name="NaoColor" value="black"/>
        <Translation x="0.42" y="-0.08" z="320mm"/>
        <Rotation z="180degree"/>
      </Body>
      <Body ref="Nao" name="robot3">
        <Set name="NaoColor" value="black"/>
        <Translation x="0.95" y="0.72" z="320mm"/>
        <Rotation z="180degree"/>
      </Body>
      <Body ref="Nao" name="robot4">
        <Set name="NaoColor" value="black"/>
        <Translation x="-4.30" y="0.00" z="320mm"/>
        <Rotation z="0degree"/>
      </Body>
      <Body ref="Nao" name="robot21">
        <Set name="NaoColor" value="red"/>
        <Translation x="-4.10" y="0.00" z="320mm"/>
        <Rotation z="0degree"/>
      </Body>
      <Body ref="Nao" name="robot22">
        <Set name="NaoColor" value="red"/>
        <Translation x="-0.34" y="0.02" z="320mm"/>
        <Rotation z="0degree"/>
      </Body>
      <Body ref="Nao" name="robot23">
        <Set name="NaoColor" value="red"/>
        <Translation x="-0.92" y="-0.74" z="320mm"/>
        <Rotation z="0degree"/>
      </Body>
    </Compound>

    <Compound name="extras"/>

    <Compound name="balls">
      <Body ref="ball">
        <Translation x="0.00" y="0.00" z="1m"/>
      </Body>
    </Compound>

    <Compound ref="field"/>
  </Scene>
</Simulation>
